# Copy this file to .env and fill in your values
# Never commit .env to git

# Snowflake
# NOTE: This PoC uses basic username/password auth for simplicity.
# For production, consider: key-pair authentication, OAuth (Azure AD / Entra ID),
# or Snowflake's native Azure Private Link integration.
# See: https://docs.snowflake.com/en/user-guide/admin-security-fed-auth-overview
SNOWFLAKE_ACCOUNT=your_snowflake_account
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=SPIKE_DB
SNOWFLAKE_SCHEMA=PUBLIC

# Azure ML — workspace
AZURE_SUBSCRIPTION_ID=your_subscription_id
AZURE_RESOURCE_GROUP=your_resource_group
AZURE_ML_WORKSPACE=your_aml_workspace_name

# Azure ML — compute
AML_COMPUTE_NAME=spike-cluster
AML_COMPUTE_SIZE=Standard_DS2_v2

# Azure ML — training environment
# Custom environment (register with: python environment/register_environment.py)
AML_ENVIRONMENT=azureml:anomaly-classifier-env:5
# Or use Microsoft's curated environment (MLflow won't work due to protobuf conflict):
# AML_ENVIRONMENT=azureml://registries/azureml/environments/lightgbm-3.3/versions/76

# Azure ML — deployed resources
AML_ENDPOINT_NAME=anomaly-classifier-endpoint
AML_MODEL_NAME=anomaly-classifier

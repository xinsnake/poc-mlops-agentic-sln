// Generated from definition.md. Do not edit directly.
{
	"name": "poc-mlops-agentic-sln",
	// https://github.com/devcontainers/images/tree/main/src/base-ubuntu
	"image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",
	"remoteUser": "vscode",
	"privileged": false,
	"shutdownAction": "stopContainer",
	"init": true,

	"customizations": {
		"vscode": {
			"settings": {
				"files.insertFinalNewline": true,
				"files.trimTrailingWhitespace": true,
				"editor.tabSize": 2
			},
			"extensions": [
				/* ---------------------------------------------------------------------------
				   GitHub Copilot
				--------------------------------------------------------------------------- */
				"GitHub.copilot",
				"GitHub.copilot-chat",

				/* ---------------------------------------------------------------------------
				   Python
				--------------------------------------------------------------------------- */
				"ms-python.python",
				// Python language support, IntelliSense, debugging, linting.

				"charliermarsh.ruff",
				// Ruff linter and formatter for Python.

				/* ---------------------------------------------------------------------------
				   Markdown and Documentation
				--------------------------------------------------------------------------- */
				"yzhang.markdown-all-in-one",
				"DavidAnson.vscode-markdownlint",
				"bierner.markdown-yaml-preamble",

				/* ---------------------------------------------------------------------------
				   Code Quality and Spelling
				--------------------------------------------------------------------------- */
				"streetsidesoftware.code-spell-checker",
				"streetsidesoftware.code-spell-checker-australian-english",

				/* ---------------------------------------------------------------------------
				   Formatting
				--------------------------------------------------------------------------- */
				"esbenp.prettier-vscode"
			]
		}
	},

	"features": {
		// Git
		"ghcr.io/devcontainers/features/git:1": {},

		// Azure CLI with Azure DevOps extension
		"ghcr.io/devcontainers/features/azure-cli:1": {
			"extensions": "azure-devops,ml"
		}
	},

	"postCreateCommand": "bash .devcontainer/post-create.sh",
	"postStartCommand": "bash .devcontainer/post-start.sh",

	"mounts": []
}
